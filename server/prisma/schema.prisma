generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String?
  phone         String?
  isActive      Boolean  @default(true)
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  businesses    Business[]
  sessions      Session[]

  @@map("users")
}

enum UserRole {
  ADMIN
  ACCOUNTANT
  USER
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Business {
  id              String   @id @default(uuid())
  userId          String
  name            String
  legalName       String?
  gstin           String?  @unique
  pan             String?
  address         Json?
  phone           String?
  email           String?
  website         String?
  logo            String?
  bankDetails     Json?
  isActive        Boolean  @default(true)
  fiscalYearStart DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parties         Party[]
  items           Item[]
  invoices        Invoice[]
  estimates       Estimate[]
  purchases       Purchase[]
  payments        Payment[]
  expenses        Expense[]
  receipts        Receipt[]
  journalEntries  JournalEntry[]
  bankAccounts    BankAccount[]
  cashAccounts    CashAccount[]
  transactions    Transaction[]
  settings        BusinessSettings?

  @@map("businesses")
}

model BusinessSettings {
  id                  String  @id @default(uuid())
  businessId          String  @unique
  currency            String  @default("INR")
  decimalPlaces       Int     @default(2)
  invoicePrefix       String  @default("INV")
  estimatePrefix      String  @default("EST")
  receiptPrefix       String  @default("RCP")
  paymentPrefix       String  @default("PAY")
  invoiceNumberFormat String?
  enableGst           Boolean @default(true)
  stateCode           String  @default("27")
  businessType        String?
  businessCategory    String?
  defaultTaxRate      Float   @default(18)

  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_settings")
}

model Party {
  id              String        @id @default(uuid())
  businessId      String
  name            String
  partyType       PartyType     @default(CUSTOMER)
  gstin           String?
  pan             String?
  email           String?
  phone           String?
  whatsapp        String?
  billingAddress  Json?
  shippingAddress Json?
  creditLimit     Float?
  openingBalance  Float         @default(0)
  balanceType     BalanceType   @default(RECEIVABLE)
  dueDays         Int           @default(0)
  taxability      String        @default("taxable")
  isRegistered    Boolean       @default(false)
  isActive        Boolean       @default(true)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  purchases       Purchase[]

  @@map("parties")
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum BalanceType {
  RECEIVABLE
  PAYABLE
}

model Item {
  id              String      @id @default(uuid())
  businessId      String
  name            String
  sku             String?
  hsnCode         String?
  barcode         String?
  description     String?
  category        String?
  unit            String      @default("NOS")
  taxRate         Float       @default(18)
  taxability      String      @default("taxable")
  sellingPrice    Float       @default(0)
  purchasePrice   Float       @default(0)
  mrp             Float?
  openingStock    Float       @default(0)
  currentStock    Float       @default(0)
  reorderLevel    Float?
  godown          String?
  imageUrl        String?
  isActive        Boolean     @default(true)
  isService       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceItems    InvoiceItem[]
  estimateItems   EstimateItem[]
  purchaseItems   PurchaseItem[]

  @@map("items")
}

model Purchase {
  id              String        @id @default(uuid())
  businessId      String
  purchaseNumber  String
  invoiceType     PurchaseType  @default(PURCHASE_INVOICE)
  partyId         String
  date            DateTime
  dueDate         DateTime?
  reverseCharge   Boolean       @default(false)
  stateOfSupply   String?
  subtotal        Float
  discountAmount  Float         @default(0)
  discountPercent Float         @default(0)
  cgstAmount      Float         @default(0)
  sgstAmount      Float         @default(0)
  igstAmount      Float         @default(0)
  cessAmount      Float         @default(0)
  roundOff        Float         @default(0)
  totalAmount     Float
  amountInWords   String?
  paidAmount      Float         @default(0)
  balanceDue      Float
  status          PurchaseStatus @default(DRAFT)
  notes           String?
  terms           String?
  billingAddress Json?
  shippingAddress Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party           Party        @relation(fields: [partyId], references: [id])
  items           PurchaseItem[]

  @@unique([businessId, purchaseNumber])
  @@map("purchases")
}

enum PurchaseType {
  PURCHASE_INVOICE
  PURCHASE_ORDER
  DEBIT_NOTE
  CREDIT_NOTE
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  PARTIAL
  PAID
  CANCELLED
}

model PurchaseItem {
  id              String  @id @default(uuid())
  purchaseId      String
  itemId          String?
  description     String
  hsnCode         String?
  quantity        Float
  unit            String  @default("NOS")
  rate            Float
  discountPercent Float  @default(0)
  discountAmount  Float  @default(0)
  taxableAmount   Float
  cgstRate        Float   @default(0)
  cgstAmount      Float   @default(0)
  sgstRate        Float   @default(0)
  sgstAmount      Float   @default(0)
  igstRate        Float   @default(0)
  igstAmount      Float   @default(0)
  cessRate        Float   @default(0)
  cessAmount      Float   @default(0)
  totalAmount     Float

  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item            Item?    @relation(fields: [itemId], references: [id])

  @@map("purchase_items")
}

model Invoice {
  id              String        @id @default(uuid())
  businessId      String
  invoiceNumber   String
  invoiceType     InvoiceType   @default(TAX_INVOICE)
  partyId         String
  date            DateTime
  dueDate         DateTime?
  reverseCharge   Boolean       @default(false)
  stateOfSupply   String?
  billingAddress  Json?
  shippingAddress Json?
  subtotal        Float
  discountAmount  Float         @default(0)
  discountPercent Float         @default(0)
  cgstAmount      Float         @default(0)
  sgstAmount      Float         @default(0)
  igstAmount      Float         @default(0)
  cessAmount      Float         @default(0)
  roundOff        Float         @default(0)
  totalAmount     Float
  amountInWords   String?
  paidAmount      Float         @default(0)
  balanceDue      Float
  status          InvoiceStatus @default(DRAFT)
  notes           String?
  terms           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]

  @@unique([businessId, invoiceNumber])
  @@map("invoices")
}

enum InvoiceType {
  TAX_INVOICE
  BILL_OF_SUPPLY
  EXPORT_INVOICE
  SEZ_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id              String  @id @default(uuid())
  invoiceId       String
  itemId          String?
  description     String
  hsnCode         String?
  quantity        Float
  unit            String  @default("NOS")
  rate            Float
  discountPercent Float  @default(0)
  discountAmount  Float  @default(0)
  taxableAmount   Float
  cgstRate        Float   @default(0)
  cgstAmount      Float   @default(0)
  sgstRate        Float   @default(0)
  sgstAmount      Float   @default(0)
  igstRate        Float   @default(0)
  igstAmount      Float   @default(0)
  cessRate        Float   @default(0)
  cessAmount      Float   @default(0)
  totalAmount     Float

  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item            Item?    @relation(fields: [itemId], references: [id])

  @@map("invoice_items")
}

model Estimate {
  id              String        @id @default(uuid())
  businessId      String
  estimateNumber  String
  partyId         String?
  partyName       String?
  date            DateTime
  expiryDate      DateTime?
  subtotal        Float
  discountAmount  Float         @default(0)
  discountPercent Float         @default(0)
  taxAmount       Float         @default(0)
  totalAmount     Float
  status          EstimateStatus @default(DRAFT)
  notes           String?
  terms           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items           EstimateItem[]

  @@unique([businessId, estimateNumber])
  @@map("estimates")
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
  EXPIRED
}

model EstimateItem {
  id              String  @id @default(uuid())
  estimateId      String
  itemId          String?
  description     String
  hsnCode         String?
  quantity        Float
  unit            String  @default("NOS")
  rate            Float
  discountPercent Float  @default(0)
  discountAmount  Float  @default(0)
  taxableAmount   Float
  cgstRate        Float   @default(0)
  cgstAmount      Float   @default(0)
  sgstRate        Float   @default(0)
  sgstAmount      Float   @default(0)
  igstRate        Float   @default(0)
  igstAmount      Float   @default(0)
  cessRate        Float   @default(0)
  cessAmount      Float   @default(0)
  totalAmount     Float

  estimate        Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  item            Item?    @relation(fields: [itemId], references: [id])

  @@map("estimate_items")
}

model Payment {
  id              String        @id @default(uuid())
  businessId      String
  paymentNumber   String
  partyId         String
  date            DateTime
  amount          Float
  paymentMethod   PaymentMethod @default(CASH)
  reference       String?
  notes           String?
  isAdjusted      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  adjustments     PaymentAdjustment[]

  @@unique([businessId, paymentNumber])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  BANK
  UPI
  CARD
  CHEQUE
  NEFT
  RTGS
}

model PaymentAdjustment {
  id              String  @id @default(uuid())
  paymentId       String
  invoiceId       String
  amount          Float

  payment         Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_adjustments")
}

model Expense {
  id              String       @id @default(uuid())
  businessId      String
  expenseNumber   String
  date            DateTime
  category        String
  description     String?
  partyId         String?
  amount          Float
  taxAmount       Float        @default(0)
  totalAmount     Float
  paymentMethod   PaymentMethod @default(CASH)
  reference       String?
  notes           String?
  attachmentUrl   String?
  status          ExpenseStatus @default(PAID)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  business        Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, expenseNumber])
  @@map("expenses")
}

enum ExpenseStatus {
  DRAFT
  PAID
  CANCELLED
}

model Receipt {
  id              String        @id @default(uuid())
  businessId      String
  receiptNumber   String
  partyId         String
  date            DateTime
  amount          Float
  paymentMethod   PaymentMethod @default(CASH)
  reference       String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, receiptNumber])
  @@map("receipts")
}

model BankAccount {
  id              String   @id @default(uuid())
  businessId      String
  bankName        String
  accountName     String
  accountNumber   String
  ifscCode        String
  branchName      String?
  accountType     String?
  openingBalance  Float    @default(0)
  currentBalance  Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("bank_accounts")
}

model CashAccount {
  id              String   @id @default(uuid())
  businessId      String
  name            String
  openingBalance  Float    @default(0)
  currentBalance  Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("cash_accounts")
}

model Transaction {
  id              String          @id @default(uuid())
  businessId      String
  date            DateTime
  type            TransactionType
  reference       String?
  partyId         String?
  bankAccountId   String?
  cashAccountId   String?
  amount          Float
  balance         Float
  narration       String?
  voucherType     String?
  createdAt       DateTime        @default(now())

  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party           Party?          @relation(fields: [partyId], references: [id])
  bankAccount     BankAccount?    @relation(fields: [bankAccountId], references: [id])
  cashAccount     CashAccount?    @relation(fields: [cashAccountId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  RECEIPT
  PAYMENT
  JOURNAL
  CONTRA
}

model JournalEntry {
  id              String   @id @default(uuid())
  businessId      String
  entryNumber     String
  date            DateTime
  description     String?
  totalDebit      Float
  totalCredit     Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lines           JournalEntryLine[]

  @@unique([businessId, entryNumber])
  @@map("journal_entries")
}

model JournalEntryLine {
  id              String  @id @default(uuid())
  journalEntryId  String
  accountType     String
  accountId       String
  debit           Float   @default(0)
  credit          Float   @default(0)
  narration       String?

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@map("journal_entry_lines")
}

model ImportLog {
  id              String        @id @default(uuid())
  businessId      String?
  importType      ImportType
  fileName        String
  fileSize        Float
  recordsTotal    Int
  recordsImported Int
  recordsFailed   Int
  errors          Json?
  status          ImportStatus  @default(PROCESSING)
  startedAt       DateTime      @default(now())
  completedAt     DateTime?

  @@map("import_logs")
}

enum ImportType {
  VYAPAR_JSON
  VYAPAR_SQLITE
  EXCEL
  CSV
  TALLY_XML
}

enum ImportStatus {
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}
