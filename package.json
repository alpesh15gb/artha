{
  "name": "artha-monorepo",
  "version": "1.0.0",
  "description": "Artha Next-Level Cloud & Native Accounting",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/web",
    "apps/api",
    "apps/desktop",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "db:migrate": "npm run db:migrate --workspace=api",
    "db:seed": "npm run db:seed --workspace=api",
    "import:vyapar": "node apps/api/import-tools/vyapar-import.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "latest",
    "prettier": "^3.2.5"
  }
}
